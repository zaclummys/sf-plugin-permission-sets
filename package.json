{
    "name": "sf-plugin-permission-sets",
    "description": "",
    "version": "0.0.0-dev",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/zaclummys/sf-plugin-permission-sets.git"
    },
    "dependencies": {
        "@oclif/core": "^4",
        "@salesforce/core": "^8",
        "@salesforce/sf-plugins-core": "^12",
        "globby": "^16.2.0",
        "yaml": "^2.9.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@salesforce/dev-scripts": "^10",
        "eslint-plugin-sf-plugin": "^1.18.6",
        "husky": "^7.0.4",
        "oclif": "^4.14.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "files": [
        "/lib",
        "/messages",
        "/oclif.manifest.json",
        "/oclif.lock"
    ],
    "keywords": [
        "force",
        "salesforce",
        "salesforcedx",
        "sf",
        "sf-plugin",
        "sfdx",
        "sfdx-plugin"
    ],
    "license": "BSD-3-Clause",
    "oclif": {
        "commands": "./lib/commands",
        "bin": "sf",
        "topicSeparator": " ",
        "devPlugins": [
            "@oclif/plugin-help"
        ],
        "topics": {
            "ps": {
                "description": "Manage permission set assignments declaratively."
            }
        },
        "flexibleTaxonomy": true
    },
    "scripts": {
        "build": "wireit",
        "clean": "sf-clean",
        "clean-all": "sf-clean all",
        "compile": "wireit",
        "docs": "sf-docs",
        "format": "wireit",
        "lint": "wireit",
        "prepare": "husky install",
        "postpack": "sf-clean --ignore-signing-artifacts",
        "prepack": "sf-prepack",
        "test": "wireit",
        "test:only": "wireit",
        "version": "oclif readme"
    },
    "publishConfig": {
        "access": "public"
    },
    "wireit": {
        "build": {
            "dependencies": [
                "compile",
                "lint"
            ]
        },
        "compile": {
            "command": "tsc -p . --pretty --incremental",
            "files": [
                "src/**/*.ts",
                "**/tsconfig.json",
                "messages/**"
            ],
            "output": [
                "lib/**",
                "*.tsbuildinfo"
            ],
            "clean": "if-file-deleted"
        },
        "format": {
            "command": "prettier --write \"src/**/*.+(ts|js|json)\"",
            "files": [
                "src/**/*.ts",
                ".prettier*"
            ],
            "output": []
        },
        "lint": {
            "command": "eslint src --color --cache --cache-location .eslintcache",
            "files": [
                "src/**/*.ts",
                "messages/**",
                "**/.eslint*",
                "**/tsconfig.json"
            ],
            "output": []
        },
        "test": {
            "dependencies": [
                "test:only",
                "lint"
            ]
        },
        "test:only": {
            "command": "vitest run",
            "env": {
                "FORCE_COLOR": "2"
            },
            "files": [
                "src/**/*.ts",
                "vitest.config.ts",
                "**/tsconfig.json"
            ],
            "output": []
        }
    },
    "exports": "./lib/index.js",
    "type": "module",
    "author": "Isaac Ferreira"
}
